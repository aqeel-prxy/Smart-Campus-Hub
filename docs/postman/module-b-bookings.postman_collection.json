{
  "info": {
    "_postman_id": "8a3f2b92-6bb5-4b86-bf5f-f67c8f2eb8c5",
    "name": "Smart Campus - Module B Bookings",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Booking",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resourceId\": \"{{resourceId}}\",\n  \"bookingDate\": \"2026-04-30\",\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"11:00:00\",\n  \"purpose\": \"Group presentation\",\n  \"expectedAttendees\": 30\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/bookings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings"
          ]
        }
      }
    },
    {
      "name": "Get My Bookings",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/bookings/my",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings",
            "my"
          ]
        }
      }
    },
    {
      "name": "Admin - Get All Bookings",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/bookings?status=PENDING",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings"
          ],
          "query": [
            {
              "key": "status",
              "value": "PENDING"
            }
          ]
        }
      }
    },
    {
      "name": "Admin - Approve Booking",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"decision\": \"APPROVED\",\n  \"reason\": \"Resource available and request valid\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/decision",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings",
            "{{bookingId}}",
            "decision"
          ]
        }
      }
    },
    {
      "name": "Cancel Booking",
      "request": {
        "method": "PATCH",
        "url": {
          "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings",
            "{{bookingId}}",
            "cancel"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "resourceId",
      "value": ""
    },
    {
      "key": "bookingId",
      "value": ""
    }
  ]
}
